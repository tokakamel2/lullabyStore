# @supabase/server reads these server-side variables.
# Copy real values from Supabase Dashboard -> Connect. Never commit the real secret key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-supabase-secret-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Next.js browser/client helpers need public aliases for login and Storage uploads.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key

# Optional comma-separated allow list. If omitted, any authenticated Supabase user can access /admin.
ADMIN_EMAILS=owner@example.com

# International format is recommended. Non-digits are stripped before opening wa.me.
NEXT_PUBLIC_WHATSAPP_PHONE=15551234567
